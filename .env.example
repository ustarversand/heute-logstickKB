# ============================================================
# 货易达物流看板 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写你的账号信息:
#   cp .env.example .env
# ============================================================

# ─── 货易达主账号 ───────────────────────────────────────────
# USTAR 账号（默认）
HEUTE_USERNAME=USTAR
HEUTE_PASSWORD=你的密码

# MSCJ 账号（可选，不需要可留空）
MSCJ_USERNAME=MSCJ
MSCJ_PASSWORD=你的密码

# ─── 看板配置 ───────────────────────────────────────────────
DASHBOARD_PORT=8890
